# ============================================================
# NSE Trading Bot -- Environment Variables
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values below
#   3. NEVER commit .env to git (it's in .gitignore)
# ============================================================

# ── Angel One SmartAPI Credentials ──────────────────────────
# Get these from: https://smartapi.angelone.in/
# Step-by-step: docs/API_SETUP.md
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_mpin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# ── Firebase Realtime Database ───────────────────────────────
# Get these from: https://console.firebase.google.com/
# Step-by-step: docs/FIREBASE_SETUP.md
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# ── Capital ───────────────────────────────────────────────────
# Starting capital in rupees
INITIAL_CAPITAL=1000

# ── Trading Mode ──────────────────────────────────────────────
# PAPER_TRADING=True  --> Simulate trades (no real orders placed)
# SUGGEST_ONLY=True   --> Show signals but don't even simulate
# Set both False for fully automated live trading
PAPER_TRADING=True
SUGGEST_ONLY=True

# ── 30-Second Confirmation Window ────────────────────────────
# If True: when a 70+ signal fires, push to dashboard with a
# 30-second countdown. You can reject it before auto-execution.
# Only relevant when SUGGEST_ONLY=False (live mode).
USE_CONFIRMATION=False

# ── News Sentiment API ────────────────────────────────────────
# Marketaux free tier: 100 requests/day
# Get your key at: https://www.marketaux.com/
# Leave blank to disable news filtering (bot still works fine)
NEWS_API_KEY=

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
